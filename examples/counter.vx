component Counter(label, items, onTap) {
  ~count = 0
  render {
    <button on:click={onTap}>{label}: {count}</button>
    {#if count}<small>active</small>{:else}<small>idle</small>{/if}
    <ul>{#each items as item, i}<li>{i}:{item}</li>{/each}</ul>
  }
}

@fast sum(a: i32, b: i32) -> i32 {
  a + b
}
