component Example04(label, items, onTap) {
  ~count = 4
  ~active = count > 0
  render {
    <section class="card">
      <button on:click={onTap}>{label}: {count}</button>
      {#if active}<p>active</p>{:else}<p>idle</p>{/if}
      <ul>{#each items as item, i}<li>{i}:{item}</li>{/each}</ul>
    </section>
  }
}

@fast add04(a: i32, b: i32) -> i32 {
  a + b
}

