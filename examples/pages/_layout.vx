component RootLayout(content, pathname) {
  render {
    <div>
      <header>
        <strong>Velox App Shell</strong>
        <small>{pathname}</small>
        <nav>
          <a href="/">Home</a>
          <a href="/about">About</a>
          <a href="/pricing">Pricing</a>
        </nav>
      </header>
      <main>{content}</main>
    </div>
  }
}