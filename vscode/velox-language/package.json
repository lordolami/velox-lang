{
  "name": "velox-vx-language",
  "displayName": "Velox VX Language",
  "description": "Velox (.vx) language support with diagnostics and LSP-style intelligence",
  "version": "0.2.3",
  "publisher": "lakesbim-velox",
  "icon": "images/velox-icon.png",
  "keywords": [
    "velox",
    "vx",
    "frontend",
    "language",
    "wasm"
  ],
  "homepage": "https://github.com/lakesbim/velox",
  "repository": {
    "type": "git",
    "url": "https://github.com/lakesbim/velox.git"
  },
  "bugs": {
    "url": "https://github.com/lakesbim/velox/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:velox",
    "onCommand:velox.checkCurrentFile"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{ recursive: true, force: true })\"",
    "bundle:extension": "esbuild extension.js --bundle --platform=node --format=cjs --target=node20 --outfile=dist/extension.js --external:vscode",
    "bundle:lsp": "esbuild lsp/server.js --bundle --platform=node --format=cjs --target=node20 --outfile=dist/lsp/server.js --external:vscode",
    "bundle": "npm run clean && npm run bundle:extension && npm run bundle:lsp",
    "vscode:prepublish": "npm run bundle"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "esbuild": "^0.25.3"
  },
  "contributes": {
    "languages": [
      {
        "id": "velox",
        "aliases": [
          "Velox",
          "velox"
        ],
        "extensions": [
          ".vx",
          ".VX"
        ],
        "icon": {
          "light": "./images/velox-file-light.svg",
          "dark": "./images/velox-file-dark.svg"
        },
        "configuration": "./language-configuration.json"
      }
    ],
    "snippets": [
      {
        "language": "velox",
        "path": "./snippets/velox.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "velox.checkCurrentFile",
        "title": "Velox: Check Current File"
      }
    ],
    "grammars": [
      {
        "language": "velox",
        "scopeName": "source.velox",
        "path": "./syntaxes/velox.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Velox",
      "properties": {
        "velox.cliPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to Velox CLI executable. When empty, the extension auto-detects local commands."
        },
        "velox.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Velox diagnostics by running `velox check` for .vx files."
        }
      }
    }
  }
}
