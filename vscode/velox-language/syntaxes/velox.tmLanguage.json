{
  "scopeName": "source.velox",
  "name": "Velox",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#fastDecorator"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#imports"
    },
    {
      "include": "#reactiveState"
    },
    {
      "include": "#directives"
    },
    {
      "include": "#events"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.velox",
          "match": "//.*$"
        }
      ]
    },
    "fastDecorator": {
      "patterns": [
        {
          "name": "storage.modifier.velox",
          "match": "@fast\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.velox",
          "match": "\\b(component|render|as)\\b"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "keyword.control.import.velox",
          "match": "\\bimport\\b"
        },
        {
          "name": "keyword.control.from.velox",
          "match": "\\bfrom\\b"
        }
      ]
    },
    "reactiveState": {
      "patterns": [
        {
          "name": "keyword.operator.reactive.velox",
          "match": "~(?=[A-Za-z_][A-Za-z0-9_]*)"
        }
      ]
    },
    "directives": {
      "patterns": [
        {
          "name": "keyword.control.directive.velox",
          "match": "\\{#if\\b[^}]*\\}|\\{#each\\b[^}]*\\}|\\{:else\\}|\\{/if\\}|\\{/each\\}"
        }
      ]
    },
    "events": {
      "patterns": [
        {
          "name": "entity.other.attribute-name.event.velox",
          "match": "\\bon:[A-Za-z_][A-Za-z0-9_-]*\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.velox",
          "match": "\\b(i32|i64|f32|f64|str|bool|any)\\b"
        },
        {
          "name": "constant.language.boolean.velox",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.velox",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.velox",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.velox",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.velox",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.velox",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.velox",
          "match": "->|==|!=|<=|>=|&&|\\|\\||[+\\-*/%=<>:]"
        }
      ]
    }
  }
}
