component NotFoundPage() {
  render {
    <section class="notfound">
      <div class="notfound-code">404</div>
      <h2>That route does not exist.</h2>
      <p>The page you asked for is missing, but the rest of Velox is still right here.</p>
      <a href="/" class="btn-cta">Back to home</a>
    </section>
  }
}
